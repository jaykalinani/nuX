# -----------------------------------------------------------------------------
# Active thorns
# -----------------------------------------------------------------------------
ActiveThorns = "
   ADMBaseX
   AsterMasks
   AsterX
   CarpetX
   Con2PrimFactory
   CoordinatesX
   Cowling
   EOSX
   Formaline
   HydroBaseX
   IOUtil
   KerrSchildX
   nuX_FakeRates
   nuX_M1
   nuX_Seeds
   nuX_Utils
   ODESolvers
   TimerReport
   TmunuBaseX
   "

# -----------------------------------------------------------------------------
# Global variables
# -----------------------------------------------------------------------------
$nlevels = 1
$ncells  = 32 #96

# Base half-cell shift so that r=0 lies on a cell face (no cell center at r=0)
$L   = 5.0
$dx  = (2.0*$L)/$ncells
$off = 0.5*$dx

$xmin = -$L + $off
$xmax = +$L + $off

#$xmin    = -5.0
#$xmax    = +5.0

# -----------------------------------------------------------------------------
# ADMBaseX / KerrSchildX
# -----------------------------------------------------------------------------
ADMBaseX::initial_data    = "kerrschildx"
ADMBaseX::initial_lapse   = "kerrschildx"
ADMBaseX::initial_shift   = "kerrschildx"
ADMBaseX::initial_dtlapse = "kerrschildx"
ADMBaseX::initial_dtshift = "kerrschildx"

KerrSchildX::mass    = 1.0
KerrSchildX::spin    = 0.0
KerrSchildX::epsilon = 1.0e-8

# -----------------------------------------------------------------------------
# AsterX
# -----------------------------------------------------------------------------
AsterX::debug_mode   = "yes"
AsterX::freeze_evolution = yes
AsterX::flux_type    = "LxF"
AsterX::update_tmunu = "no"

# -----------------------------------------------------------------------------
# Cactus
# -----------------------------------------------------------------------------
Cactus::cctk_show_schedule = yes
Cactus::presync_mode       = "mixed-error"
Cactus::terminate          = "time"
Cactus::cctk_final_time    = 20.0

# -----------------------------------------------------------------------------
# CarpetX
# -----------------------------------------------------------------------------
CarpetX::verbose = yes

CarpetX::xmin = $xmin
CarpetX::ymin = $xmin
CarpetX::zmin = $xmin

CarpetX::xmax = $xmax
CarpetX::ymax = $xmax
CarpetX::zmax = $xmax

CarpetX::periodic   = no
CarpetX::periodic_x = no
CarpetX::periodic_y = no
CarpetX::periodic_z = no

CarpetX::boundary_x       = "linear extrapolation"
CarpetX::boundary_y       = "linear extrapolation"
CarpetX::boundary_z       = "linear extrapolation"
CarpetX::boundary_upper_x = "linear extrapolation"
CarpetX::boundary_upper_y = "linear extrapolation"
CarpetX::boundary_upper_z = "linear extrapolation"

CarpetX::ncells_x = $ncells
CarpetX::ncells_y = $ncells
CarpetX::ncells_z = $ncells

CarpetX::max_num_levels         = $nlevels
CarpetX::regrid_every           = 100000
CarpetX::blocking_factor_x      = 1
CarpetX::blocking_factor_y      = 1
CarpetX::blocking_factor_z      = 1
CarpetX::regrid_error_threshold = 0.01

CarpetX::prolongation_type = "ddf"
CarpetX::ghost_size        = 3
CarpetX::dtfac             = 0.25

CarpetX::out_norm_every         = 50
CarpetX::out_norm_omit_unstable = yes
CarpetX::out_norm_vars          = "all"

CarpetX::out_tsv_vars = "
    ADMBaseX::lapse
    ADMBaseX::shift
    ADMBaseX::metric
    nuX_M1::rN
    nuX_M1::rE
    nux_M1::rf
    nuX_M1::rP
    nuX_M1::chi
    nuX_M1::rnnu
    nuX_M1::rJ
    nuX_M1::rHt
    nuX_M1::rH
    nuX_M1::fidu_vel
    nuX_M1::opacs
    nuX_M1::nu_flux_x
    nuX_M1::nu_flux_y
    nuX_M1::nu_flux_z
    nuX_M1::radial_fluxes
"

# -----------------------------------------------------------------------------
# Con2PrimFactory
# -----------------------------------------------------------------------------
Con2PrimFactory::c2p_prime   = "Noble"
Con2PrimFactory::c2p_second  = "Palenzuela"
Con2PrimFactory::c2p_tol     = 1e-8
Con2PrimFactory::max_iter    = 100
Con2PrimFactory::rho_abs_min = 1e-8
Con2PrimFactory::unit_test   = "yes"
Con2PrimFactory::B_lim       = 1e8
Con2PrimFactory::vw_lim      = 1e8
Con2PrimFactory::Ye_lenient  = "yes"

# -----------------------------------------------------------------------------
# EOSX
# -----------------------------------------------------------------------------
EOSX::evolution_eos = "IdealGas"
EOSX::gl_gamma      = 2.0
EOSX::poly_gamma    = 2.0
EOSX::rho_max       = 1e8
EOSX::eps_max       = 1e8

# -----------------------------------------------------------------------------
# IO
# -----------------------------------------------------------------------------
IO::out_dir   = $parfile
IO::out_every = 20

# -----------------------------------------------------------------------------
# ODESolvers
# -----------------------------------------------------------------------------
ODESolvers::method = "RK4"

# -----------------------------------------------------------------------------
# ReconX
# -----------------------------------------------------------------------------
ReconX::reconstruction_method = "wenoz"

# -----------------------------------------------------------------------------
# TimerReport
# -----------------------------------------------------------------------------
TimerReport::out_every                  = 200
TimerReport::out_filename               = "TimerReport"
TimerReport::output_all_timers_together = yes
TimerReport::output_all_timers_readable = yes
TimerReport::n_top_timers               = 50

# -----------------------------------------------------------------------------
# nuX_FakeRates
# -----------------------------------------------------------------------------
nuX_FakeRates::eta_nue        = 0.0
nuX_FakeRates::eta_nua        = 0.0
nuX_FakeRates::eta_nux        = 0.0
nuX_FakeRates::kappa_scat_nue = 0.0
nuX_FakeRates::kappa_scat_nua = 0.0
nuX_FakeRates::kappa_scat_nux = 0.0
nuX_FakeRates::kappa_abs_nue  = 0.0
nuX_FakeRates::kappa_abs_nua  = 0.0

# -----------------------------------------------------------------------------
# nuX_M1
# -----------------------------------------------------------------------------
nuX_M1::add_to_Tmunu         = "no"
nuX_M1::backreact            = "no"
nuX_M1::bc_type              = "flat"
nuX_M1::closure              = "Minerbo"
nuX_M1::closure_epsilon      = 1e-5
nuX_M1::closure_maxiter      = 1000
nuX_M1::copy_levels          = "yes"
nuX_M1::fiducial_velocity    = "lab"
nuX_M1::include_fluxes       = "yes"
nuX_M1::include_GR_sources   = "yes"
nuX_M1::minmod_theta         = 1.0
nuX_M1::source_epsabs        = 1e-8
nuX_M1::reset_to_equilibrium = "no"
nuX_M1::use_fakerates        = "yes"
nuX_M1::verbose              = "yes"

# -----------------------------------------------------------------------------
# nuX_Seeds
# -----------------------------------------------------------------------------
nuX_Seeds::verbose            = "yes"
nuX_Seeds::nuX_test_case      = "kerrschild"
nuX_Seeds::kerr_beam_position = 3.25
nuX_Seeds::kerr_beam_width    = 0.5
nuX_Seeds::kerr_mask_radius   = 1.0
