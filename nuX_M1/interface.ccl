    transport_flowN_Lx, transport_flowN_Ly, transport_flowN_Lz,
    transport_flowN_Rx, transport_flowN_Ry, transport_flowN_Rz
} "Per-direction left/right low-order interface fluxes for the radiation number density"

CCTK_REAL transport_fluxlow_E[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_flowE_Lx, transport_flowE_Ly, transport_flowE_Lz,
