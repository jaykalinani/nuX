    transport_divN_x, transport_divN_y, transport_divN_z
} "Per-direction transport divergence contribution to the radiation number-density RHS"

CCTK_REAL transport_rhsdiv_E[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_divE_x, transport_divE_y, transport_divE_z
