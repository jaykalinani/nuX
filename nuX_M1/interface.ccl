{
    transport_duN_Lx, transport_duN_Ly, transport_duN_Lz,
    transport_duN_Rx, transport_duN_Ry, transport_duN_Rz
} "Per-direction left/right state jumps entering the low-order numerical flux for the radiation number density"

CCTK_REAL transport_statejump_E[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_duE_Lx, transport_duE_Ly, transport_duE_Lz,
