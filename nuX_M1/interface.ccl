# Interface definition for thorn nuX_M1
IMPLEMENTS: nuX_M1
INHERITS: ADMBaseX AsterX CarpetXRegrid HydroBaseX TmunuBaseX

INCLUDES HEADER: nuX_M1_macro.hxx IN nuX_M1_macro.hxx
INCLUDES HEADER: nuX_M1_closure.hxx IN nuX_M1_closure.hxx 

USES INCLUDE HEADER: aster_fd.hxx aster_interp.hxx aster_utils.hxx
USES INCLUDE HEADER: nuX_metric.hxx nuX_pow.hxx nuX_tensor.hxx nuX_valencia.hxx nuX_utils.hxx
USES INCLUDE HEADER: roots.hxx
USES INCLUDE HEADER: m1_opacities.hpp
USES INCLUDE HEADER: avg_baryon_mass.hpp
USES INCLUDE HEADER: nuX_fakerates.hxx

# === External functions ===

# Carpet
CCTK_INT FUNCTION EnableProlongating(CCTK_INT IN status)
USES FUNCTION EnableProlongating

CCTK_INT FUNCTION QueryProlongating()
USES FUNCTION QueryProlongating


# === Public grid functions ===

PUBLIC:

##TODO: add correct dependents and tags for checkpointing

CCTK_REAL rN[nspecies*ngroups] TYPE=GF TIMELEVELS=2 CENTERING={ccc} TAGS='checkpoint="yes"' "Neutrino density in the lab frame"

CCTK_REAL rE[nspecies*ngroups] TYPE=GF TIMELEVELS=2 CENTERING={ccc} TAGS='checkpoint="yes"' "Radiation energy density in the lab frame"

CCTK_REAL rF[nspecies*ngroups] TYPE=GF TIMELEVELS=2 CENTERING={ccc} TAGS='checkpoint="yes"' 
{
    rFx, rFy, rFz
} "Radiation energy flux in the lab frame"

CCTK_REAL rP[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="yes"'
{
    rPxx, rPxy, rPxz, rPyy, rPyz, rPzz
} "Radiation pressure in the lab frame, normalized with E"

## TODO: add timelevels infrastructure, for now defining previous time_levels explicitly

#CCTK_REAL rN_p[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="yes"' "Neutrino density in the lab frame for previous timelevel"
#
#CCTK_REAL rE_p[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='rhs="rE_rhs" checkpoint="yes"' "Radiation energy density in the lab frame for previous time level"
#
#CCTK_REAL rF_p[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='rhs="rF_rhs" checkpoint="yes"'
#{
#    rFx_p, rFy_p, rFz_p
#} "Radiation energy flux in the lab frame for previous time level"

## Fluid frame quantities
CCTK_REAL rnnu[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Neutrino density in the fluid frame"

CCTK_REAL rJ[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Radiation energy density in the fluid frame"

CCTK_REAL rHt[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Radiation energy flux in the fluid frame"

CCTK_REAL rH[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    rHx, rHy, rHz
} "Radiation energy flux in the fluid frame"

CCTK_REAL nuX_m1_mask TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Mask points that should not be evolved"

# === Private grid functions ===

PRIVATE:

## neutrino fluxes in x-direction
CCTK_REAL nu_flux_x[nspecies*ngroups*5] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Neutrino flux components in the x-direction: 5 fields per (species,group)"

# neutrino fluxes in y-direction
CCTK_REAL nu_flux_y[nspecies*ngroups*5] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Neutrino flux components in the y-direction: 5 fields per (species,group)"

# neutrino fluxes in z-direction
CCTK_REAL nu_flux_z[nspecies*ngroups*5] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Neutrino flux components in the z-direction: 5 fields per (species,group)"

# characteristic speeds in x-direction
CCTK_REAL nu_cmax_x[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Maximum characteristic speed in the x-direction for each (species,group)"

# characteristic speeds in y-direction
CCTK_REAL nu_cmax_y[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Maximum characteristic speed in the y-direction for each (species,group)"

# characteristic speeds in z-direction
CCTK_REAL nu_cmax_z[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Maximum characteristic speed in the z-direction for each (species,group)"

## Diagnostics
CCTK_REAL radial_fluxes[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' 
{
    radial_flux_0, radial_flux_1
} "Neutrino radial number and energy fluxes"

## Radiation-matter interaction
CCTK_REAL opacs[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    abs_0, abs_1, eta_0, eta_1, scat_1
} "Opacity variables"

CCTK_REAL nueave[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Neutrino average energy (in equilibrium or in the energy group)"

CCTK_REAL fluidsources TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    netabs, netheat
} "Net number and energy absorption (for analysis only)"

CCTK_REAL source_update_status[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Implicit source update status: -2 not called, -1 masked, 0 OK, 1 thin, 2 Eddington fallback, 3 equilibrium, 4 scattering, 5 fail"

CCTK_REAL source_update_tau[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    source_tau_abs, source_tau_scat, source_tau_tot
} "Per-substep source coupling strengths dt*kabs, dt*kscat, and dt*(kabs+kscat)"

CCTK_REAL source_limiter_theta TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Limiter applied to the radiation-matter source update"

CCTK_REAL closure_status[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Pre-transport closure status: 0 OK, 1 no bracket, 2 setup fail, 3 solver fail, 4 nonfinite root, 5 nonfinite chi"

CCTK_REAL closure_update_status[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Update/source closure status: 0 OK, 1 no bracket, 2 setup fail, 3 solver fail, 4 nonfinite root, 5 nonfinite chi"

CCTK_REAL neutrino_fractions TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' 
{
    ynue, ynua, ynux,
    znue, znua, znux
} "Neutrino fractions (for analysis only)"

## Internal variables
CCTK_REAL fidu_vel TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    fidu_velx, fidu_vely, fidu_velz
} "Effective velocity v^i"

CCTK_REAL fidu_w_lorentz TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Effective Lorentz factor W"

CCTK_REAL chi[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "M1 closure coefficient"

CCTK_REAL rN_rhs[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "RHS for the radiation number density"

CCTK_REAL rE_rhs[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "RHS for the radiation energy density"

##TODO: check for centering
CCTK_REAL rF_rhs[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    rFx_rhs, rFy_rhs, rFz_rhs
} "RHS for the radiation energy fluxes"

CCTK_REAL rN_rhs_transport[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Transport-only RHS snapshot for the radiation number density"

CCTK_REAL rE_rhs_transport[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Transport-only RHS snapshot for the radiation energy density"

CCTK_REAL rF_rhs_transport[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    rFx_rhs_transport, rFy_rhs_transport, rFz_rhs_transport
} "Transport-only RHS snapshot for the radiation energy fluxes"

PUBLIC:

CCTK_REAL rN_bc_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "State snapshot immediately after boundary conditions for the radiation number density"

CCTK_REAL rE_bc_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "State snapshot immediately after boundary conditions for the radiation energy density"

CCTK_REAL rF_bc_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    rFx_bc_snapshot, rFy_bc_snapshot, rFz_bc_snapshot
} "State snapshot immediately after boundary conditions for the radiation energy fluxes"

CCTK_REAL rN_postupdate_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "State snapshot immediately after CalcUpdate and before timestep boundary conditions"

CCTK_REAL rE_postupdate_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "State snapshot immediately after CalcUpdate and before timestep boundary conditions"

CCTK_REAL rF_postupdate_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    rFx_postupdate_snapshot, rFy_postupdate_snapshot, rFz_postupdate_snapshot
} "State snapshot immediately after CalcUpdate and before timestep boundary conditions"

CCTK_REAL rN_prepostbc_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "State snapshot in PostStep before the poststep boundary-condition group"

CCTK_REAL rE_prepostbc_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "State snapshot in PostStep before the poststep boundary-condition group"

CCTK_REAL rF_prepostbc_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    rFx_prepostbc_snapshot, rFy_prepostbc_snapshot, rFz_prepostbc_snapshot
} "State snapshot in PostStep before the poststep boundary-condition group"

CCTK_REAL rN_preflux_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "State snapshot immediately before CalcFluxes after conserved/derived sync"

CCTK_REAL rE_preflux_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "State snapshot immediately before CalcFluxes after conserved/derived sync"

CCTK_REAL rF_preflux_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    rFx_preflux_snapshot, rFy_preflux_snapshot, rFz_preflux_snapshot
} "State snapshot immediately before CalcFluxes after conserved/derived sync"

CCTK_REAL rP_preflux_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    rPxx_preflux_snapshot, rPxy_preflux_snapshot, rPxz_preflux_snapshot,
    rPyy_preflux_snapshot, rPyz_preflux_snapshot, rPzz_preflux_snapshot
} "Closure pressure-tensor snapshot immediately before CalcFluxes after derived sync"

CCTK_REAL chi_preflux_snapshot[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Closure coefficient snapshot immediately before CalcFluxes after derived sync"

PRIVATE:

CCTK_REAL rN_transport_input[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Stage-local conserved number density used by transport kernels"

CCTK_REAL rE_transport_input[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"' "Stage-local conserved energy density used by transport kernels"

CCTK_REAL rF_transport_input[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    rFx_transport_input, rFy_transport_input, rFz_transport_input
} "Stage-local conserved flux used by transport kernels"

CCTK_REAL transport_cmax[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_cmax_Lx, transport_cmax_Ly, transport_cmax_Lz,
    transport_cmax_Rx, transport_cmax_Ry, transport_cmax_Rz
} "Per-direction left/right characteristic speeds used by the transport numerical flux"

CCTK_REAL transport_A[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_A_Lx, transport_A_Ly, transport_A_Lz,
    transport_A_Rx, transport_A_Ry, transport_A_Rz
} "Per-direction left/right A-factors used by the transport numerical flux"

CCTK_REAL transport_flux_N[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_FN_Lx, transport_FN_Ly, transport_FN_Lz,
    transport_FN_Rx, transport_FN_Ry, transport_FN_Rz
} "Per-direction left/right numerical fluxes for the radiation number density"

CCTK_REAL transport_flux_E[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_FE_Lx, transport_FE_Ly, transport_FE_Lz,
    transport_FE_Rx, transport_FE_Ry, transport_FE_Rz
} "Per-direction left/right numerical fluxes for the radiation energy density"

CCTK_REAL transport_physflux_N_x[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_fphysN_Lx, transport_fphysN_Cx, transport_fphysN_Rx
} "X-direction cell-centred physical fluxes entering the radiation number-density numerical flux"

CCTK_REAL transport_physflux_N_y[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_fphysN_Ly, transport_fphysN_Cy, transport_fphysN_Ry
} "Y-direction cell-centred physical fluxes entering the radiation number-density numerical flux"

CCTK_REAL transport_physflux_N_z[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_fphysN_Lz, transport_fphysN_Cz, transport_fphysN_Rz
} "Z-direction cell-centred physical fluxes entering the radiation number-density numerical flux"

CCTK_REAL transport_physflux_E_x[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_fphysE_Lx, transport_fphysE_Cx, transport_fphysE_Rx
} "X-direction cell-centred physical fluxes entering the radiation energy-density numerical flux"

CCTK_REAL transport_physflux_E_y[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_fphysE_Ly, transport_fphysE_Cy, transport_fphysE_Ry
} "Y-direction cell-centred physical fluxes entering the radiation energy-density numerical flux"

CCTK_REAL transport_physflux_E_z[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_fphysE_Lz, transport_fphysE_Cz, transport_fphysE_Rz
} "Z-direction cell-centred physical fluxes entering the radiation energy-density numerical flux"

CCTK_REAL transport_fluxavg_N[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_favgN_Lx, transport_favgN_Ly, transport_favgN_Lz,
    transport_favgN_Rx, transport_favgN_Ry, transport_favgN_Rz
} "Per-direction left/right average-physical-flux term in the low-order numerical flux for the radiation number density"

CCTK_REAL transport_fluxavg_E[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_favgE_Lx, transport_favgE_Ly, transport_favgE_Lz,
