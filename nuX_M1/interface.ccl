    transport_fdissN_Lx, transport_fdissN_Ly, transport_fdissN_Lz,
    transport_fdissN_Rx, transport_fdissN_Ry, transport_fdissN_Rz
} "Per-direction left/right diffusive term 0.5*cmax*du in the low-order numerical flux for the radiation number density"

CCTK_REAL transport_fluxdiss_E[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_fdissE_Lx, transport_fdissE_Ly, transport_fdissE_Lz,
    transport_fdissE_Rx, transport_fdissE_Ry, transport_fdissE_Rz
} "Per-direction left/right diffusive term 0.5*cmax*du in the low-order numerical flux for the radiation energy density"

