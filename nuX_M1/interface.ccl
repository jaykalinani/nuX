} "Per-direction left/right limiter phi values for the radiation number density"

CCTK_REAL transport_limiter_E[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_phiE_Lx, transport_phiE_Ly, transport_phiE_Lz,
    transport_phiE_Rx, transport_phiE_Ry, transport_phiE_Rz
} "Per-direction left/right limiter phi values for the radiation energy density"

