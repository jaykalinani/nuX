{
    transport_sawN_Lx, transport_sawN_Ly, transport_sawN_Lz,
    transport_sawN_Rx, transport_sawN_Ry, transport_sawN_Rz
} "Per-direction left/right sawtooth flags for the radiation number density"

CCTK_REAL transport_saw_E[nspecies*ngroups] TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_sawE_Lx, transport_sawE_Ly, transport_sawE_Lz,
    transport_sawE_Rx, transport_sawE_Ry, transport_sawE_Rz
} "Per-direction left/right sawtooth flags for the radiation energy density"

