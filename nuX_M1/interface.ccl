CCTK_REAL transport_trace_Ez TYPE=GF CENTERING={ccc} TAGS='checkpoint="no"'
{
    transport_uE_jm2_z, transport_uE_jm1_z, transport_uE_j_z, transport_uE_jp1_z, transport_uE_jp2_z,
    transport_idxE_jm2_z, transport_idxE_jm1_z, transport_idxE_j_z, transport_idxE_jp1_z, transport_idxE_jp2_z
} "Debug trace of the exact z-stencil values and linear indices used for the species-0 radiation-energy update"

CCTK_INT TimeIntegratorStage TYPE=SCALAR TAGS='checkpoint="no"' "Current stage of the time integrator"
